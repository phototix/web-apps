DirectoryIndex index.php

# Disable MultiViews to prevent Apache from guessing file extensions
Options -MultiViews

RewriteEngine On

# If the request is for a valid file, serve it
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# If the request is for a valid directory, serve it
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Otherwise, route everything to index.php
RewriteRule ^ index.php [L]